# BioTrack - Firebase & Vercel Environment Variables Example
# DO NOT include credentials in this file. Copy this to a local .env file (excluded from git) to configure your environment.

# 1. Firebase Admin SDK Credentials (Backend)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# 2. Firebase Client SDK Web App Credentials (Frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
