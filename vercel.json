{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/:path*",
      "destination": "/dist/assets/:path*"
    },
    {
      "source": "/favicon.svg",
      "destination": "/dist/favicon.svg"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/dist/index.html"
    }
  ]
}
